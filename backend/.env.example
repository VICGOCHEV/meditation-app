DATABASE_URL=postgresql://api:CHANGE_ME@127.0.0.1:5432/meditation_app?schema=public
JWT_SECRET=CHANGE_ME_RUN_node_-e_console.log(crypto.randomBytes(32).toString('base64'))
HOST=127.0.0.1
PORT=3001
NODE_ENV=production

# ── CMS (своя, замена Strapi) ───────────────────────────────────────────────
# Папка для загруженного аудио. На проде — абсолютный путь вне репо-чекаута.
UPLOAD_DIR=/opt/meditation-app/uploads
# Публичный префикс URL медиа (отдаёт Caddy на проде, Fastify локально).
MEDIA_URL_BASE=/cms-media
# TTL админ-токена и лимит размера аудио (60 МБ по умолчанию).
ADMIN_JWT_TTL=12h
MAX_AUDIO_BYTES=62914560
